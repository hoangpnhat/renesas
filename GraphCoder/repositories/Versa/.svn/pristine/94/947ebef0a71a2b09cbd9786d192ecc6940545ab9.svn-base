// Enable Data log printing
// PRINT_GENERAL_DATALOG	// remove to skip general datalog
// PRINT_TEST_DATALOG		// remove to skip site datalog
// PRINT_EMPTY_DATALOG		// add to print datalog for sites with no info.


// use 16.6 cpi on HPLJ II connected to LPT1
PRINTER_PATH lpt1
PRINT_SETUP_STRING \eE\e&l0o8D\e(1L\e(s16.6H
PRINT_PAGE_HEADER  Wafer Summary TESTER: (ttt)\tWAFER: (www)\t\tLOT: (llllllllllllllllllllllllll)\t\tPAGE: (ppp)\n\n
PRINT_PAGE_LENGTH 77


// NO_PRINT_SUMMARIES		// Never print summaries (LPT1)
// ENABLE_PRINT_SUMMARIES	// Always print summaries
REQUESTED_PRINT_SUMMARIES	// Print only menu requested summaries

NO_SITE_SUMMARIES		// Never generate site summaries
// ENABLE_SITE_SUMMARIES	// Always generate site summaries
// REQUESTED_SITE_SUMMARIES	// Print only Menu Requested site summaries.


// Specify File copy Options.  Copy files to specified path
// if specified otherwise do nothing
//
//WAFER_NET_PATH c:\TESTOUT\R%w_run(%%0.7s)%\W%w_wafer(%%0.7s)%
//WAFER_BACKUP_PATH x:\BACK
//DLOG_NET_PATH x:\NET
//DLOG_BACKUP_PATH x:\BACK
//SUMMARY_NET_PATH X:\NET
//SUMMARY_BACKUP_PATH x:\BACK
//PLAN_NET_PATH x:\NET
//PLAN_BACKUP_PATH x:\BACK

[end summary_switches]
