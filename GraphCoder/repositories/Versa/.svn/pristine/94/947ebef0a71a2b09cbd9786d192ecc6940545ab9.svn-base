////////////////////////////////////////////////////////////////////////////
/////////////////	Test station setup control switches   //////////////
////////////////////////////////////////////////////////////////////////////
[configuration_switches]

// RUN PROGRAM MENU CHOICES
EXTERNAL_PROGRAM N:\bin\do-pif.dvp
EXTERNAL_PROGRAM N:\BIN\vl-pif.dvp

ENABLE_CRM_TIMING_SWITCH OFF

IGNORE_INITIALIZE_ERRORS        // or = OFF
TEST_PLAN_WARNING OFF

ENABLE_SLAVE_MODE
DISPLAY_PHYSICAL_SITE	OFF
TESTER_ID V5000-13

[end configuration_switches]

////////////////////////////////////////////////////////////////////////////
/////////////////	Test program setup control switches   //////////////
////////////////////////////////////////////////////////////////////////////
[test_switches]


/////////////////	Program file definitions	//////////////////

USE_REMOTE_FILES
DEVICE_TYPE		RC04EX

PROGRAM_FILE    	P:\src\User\Flash\SOTB_IO\obj\RC04EX.ppcout
VECTOR			P:\src\User\Flash\SOTB_IO\obj\RC04EX.vec

PROGRAM_VERSION 0
///////////////// Test option switches //////////////////

SORT_FLOW		1
SORT_TYPE		WAFER	// DIE or WAFER

VALIDATE		0x14	// 1 = dv lock,
				// 2 = menu lock,
				// 4 = setup validate,
				// 0x8 = disable EX commands
				// 0x10 = checksums,
				// 0x20 = check device, revision
				// 0x100 = Wafer numbers

//	ENABLE_SLAVE_MODE	// 96 pin mode when present
//	DIAGNOSTICS wafer	// LOT, WAFER, #
NOINIT				// skip initialization when present.

[end test_switches]



//////////////////////////////////////////////////////////////////////
/////////////////	Prober setup control switches	//////////////
//////////////////////////////////////////////////////////////////////
[interface_switches]

DEFINE_DUT DUT=1 PROBER=0,0,1 TSITE=A1a
DEFINE_DUT DUT=2 PROBER=1,0,2 TSITE=A1b
DEFINE_DUT DUT=3 PROBER=0,1,3 TSITE=A1c
DEFINE_DUT DUT=4 PROBER=1,1,4 TSITE=A1d

XMIN  84 /*0*/
YMIN  46/*0*/
XSIZE 60 /*34*/			// 8inch wafer 18 x 18
YSIZE 60 /*34*/			// 8inch wafer 18 x 18
XMUL 1
YMUL 1

REJECT 0=0,3,1			// reject bin=ifc, color, print
REJECT 1=1,0xd,1

OFF_WAFER_MASK FAIL		// legal 0 only bad die (ALL for all die)
//	LEGAL Bin=X,Y
//	MODE  mode=X,Y
//	PROBE
//	MONITOR

//	 Define Test Modes
//	 DEFINE_MODE mode = dlog , lya , var1 , var2
DEFAULT_MODE	1
DEFINE_MODE		0 = 0xfffff, 0, 0, 0
DEFINE_MODE		1 = 0, 0, 0, 0
DEFINE_MODE		255 = 0x000000ff, 0xffffffff, 0, 0

[end interface_switches]


/////////////////////////////////////////////////////////////////
/////////////////	Summary control switches  ///////////////
/////////////////////////////////////////////////////////////////
[summary_switches]

DLOG_CAPTURE	ON		// ON or OFF
SAVE_TEST_DATALOG			// Save DataLog to SummaryFile
MIN_LOT_SPACE 4000000		// min disk space check for a lot
MIN_SUMMARY_SPACE 2000000	// min disk space check for a wafer
MAX_FILE_AGE 3				// Days of File Age
PROCESSED_FILE_AGE 3		// Days of Processed File Age


