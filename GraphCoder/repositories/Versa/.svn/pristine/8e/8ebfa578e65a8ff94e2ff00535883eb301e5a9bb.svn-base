@pattern RAM_BOOT_PATTERN
{

RAM_BOOT_CTRL:entry
        EXTCYL2,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=20000;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,call SUB_MODEENTRY_RAM;
//        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,call SUB_RAMBT_POLL;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,LP_CLK_H,XCOUT_L,DEBUG_L,call SUB_RAMBT_END;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,quit;

USER_BOOT_CTRL:entry
        EXTCYL,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,rerr;
        EXTCYL,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,LP_CLK_L;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=20000;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,call SUB_MODEENTRY_ROM;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,call SUB_RAMBT_END;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,quit;

RAM_BOOT_LPREAD:entry
        EXTCYL2,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=20000;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,call SUB_MODEENTRY_RAM;
//        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,call SUB_RAMBT_POLL;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_L,call SUB_RAMBT_END_LPREAD;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,quit;

RAM_BOOT_CTRL_RESH:entry
        EXTCYL2,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=20000;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,call SUB_MODEENTRY_RAM;
        //EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_L,call SUB_RAMBT_END;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,POLL_NC,a1=20;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,POLL_NC,a<-a1;
boot_time_loop:
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,POLL_NC,rpt=50000; /* 5ms @ 100ns */
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,POLL_NC,rpt=50000; /* 5ms @ 100ns */
        EXTCYL,CLK,RES_H,BOOT_CTRL1, POLL_NC,jump (!atc) boot_time_loop, a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, POLL_CP;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,POLL_NC,quit;

RAM_BOOT_CTRL_RESH_RELAY:entry
        EXTCYL,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,rerr;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=20000;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,call SUB_MODEENTRY_RAM;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,call SUB_RAMBT_END_RES_H;
        //EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,RELAY_LB3_ON;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,DEBUG_L,rpt=10;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,DEBUG_H,rpt=10;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,DEBUG_L,rpt=10;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,DEBUG_H,rpt=10;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L;
#if ( PRODUCT_NAME==PRODUCT_EUROPA )
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,RELAY_LB3_OFF,quit;
#elif ( PRODUCT_NAME==PRODUCT_IO )
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,RELAY_LB3_ON,quit;
#endif

RAM_BOOT_CTRL_RESL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rpt=100;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,    RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,quit;

RAM_BOOT_CTRL_PE:entry
        EXTCYL,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=20000;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,call SUB_MODEENTRY_RAM;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_L,call SUB_RAMBT_END_PE;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,quit;

RAM_BOOT_MONITOR_CTRL:entry							 
        EXTCYL2,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,rerr;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=5;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,call SUB_MODEENTRY_RAM;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,call SUB_RAMBT_POLL;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,quit;
	
RAM_BOOT_MONITOR_CRY:entry							 
        EXTCYL,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,rerr;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=5;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,call SUB_MODEENTRY_RAM_CRY;
//        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,call SUB_RAMBT_POLL;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,quit;

RAM_BOOT_MONITOR_PMU:entry							 
        EXTCYL,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,rerr;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=5;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,call SUB_MODEENTRY_RAM;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,call SUB_RAMBT_POLL,DEBUG_L;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_H,pmustb,rpt=5;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_L       ,rpt=100;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,DEBUG_L,quit;

RAM_BOOT_MONITOR_PMU_ONLY:entry							 
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_L,rpt=1000;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_H,pmustb,rpt=5;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_L,rpt=100;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_L,quit;

RAM_BOOT_MONITOR_POLL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_H,call SUB_RAMBT_POLL;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,quit;

RAM_BOOT_MONITOR_END:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_L,call SUB_RAMBT_END;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,quit;

RAM_BOOT_DELAYTEST:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L,rpt=10;
        EXTCYL2,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_H;
        EXTCYL2,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DELAY_L;	
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,rpt=10;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,quit;
	
RAM_BOOT_TCHECK:entry
        EXTCYL2,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=20000;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,call SUB_MODEENTRY_RAM;
	    EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_H,rpt=1000;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,DEBUG_L,call SUB_RAMBT_TCEHCK_POLL;
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1, DAXS_DATA_NC,quit;

RAM_BOOT_PE_IVCC:entry
        EXTCYL,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=20000;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,call SUB_MODEENTRY_RAM;
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1, DAXS_DATA_NC,quit;

RAM_BOOT_RELAY:entry
        EXTCYL,CLK_L,RES_H,RELAY_00,DEBUG_H,rpt=50;
        EXTCYL,CLK_L,RES_H,RELAY_00,DEBUG_L,rpt=50;
        EXTCYL,CLK_L,RES_H,RELAY_00,DEBUG_H,rpt=50;
        EXTCYL,CLK_L,RES_H,RELAY_00,DEBUG_L,quit;
	
RAM_BOOT_DEND_POLL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,DEBUG_L,rpt=50;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,DEBUG_H,call SUB_RAMBT_DEND_POLL;
        EXTCYL,CLK,      BOOT_CTRL1,DEBUG_L,quit;

RAM_BOOT_TCHECK_MONITOR:entry
        EXTCYL2,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=20000;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,call SUB_MODEENTRY_RAM;
        EXTCYL,CLK,RES_H,BOOT_CTRL1, DAXS_DATA_NC,LP_CLK_H,XCOUT_L,DEBUG_L,call SUB_TCHECK_MONITOR;
        EXTCYL,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,quit;

RAM_BOOT_DPASS_H_POLL:entry
        EXTCYL ,CLK_L,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL ,CLK  ,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,call SUB_RAMBT_DPASS_H_POLL;
        EXTCYL ,CLK_L,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,quit;
RAM_BOOT_DPASS_L_POLL:entry
        EXTCYL ,CLK_L,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL ,CLK  ,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,call SUB_RAMBT_DPASS_L_POLL;
        EXTCYL ,CLK_L,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,quit;

RAM_BOOT_DENDWAIT_POLLCHECK:entry
        EXTCYL ,CLK_L,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL ,CLK  ,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,call SUB_RAMBT_DEND_H_POLL;
        EXTCYL ,CLK  ,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,rerr;
        EXTCYL ,CLK  ,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,DEBUG_H,rpt = 120;
        EXTCYL ,CLK  ,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,DPASS_CP;
        EXTCYL ,CLK  ,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,DEBUG_H,rpt = 120;
        EXTCYL ,CLK_L,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,quit;

RAM_BOOT_DEND_L_WAIT:entry
        EXTCYL ,CLK_L,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL ,CLK  ,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,call SUB_RAMBT_DEND_L_POLL;
        EXTCYL ,CLK_L,RES_H,BOOT_CTRL1 ,DAXS_DATA_NC,quit;
}

@pattern DUMMY_PATTERN
{

DUMMY_MODE_ENTRY:entry
        EXTCYL,    RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rerr;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=20000;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=20000;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,quit;


}


@subroutine RAMBT_CTRL
{
SUB_RAMBT_POLL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,a1=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DELAY_L,b1=200;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,a<-a1;
j1_poll_check_wait:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b1;
j2_poll_check_wait:								   
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=200;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (!btc) j2_poll_check_wait,b--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (!atc) j1_poll_check_wait,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,ret;

SUB_RAMBT_END:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,b2=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b2;
j3_ram_keepb_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,a2=2000;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,a<-a2;
j1_ram_keepa_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=100;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_CP,DEBUG_L;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=100;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (ferr) j2_ram_end_check;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!atc) j1_ram_keepa_check,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!btc) j3_ram_keepb_check,b--;
j2_ram_end_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=20000;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,    RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,    RES_L,MODE_ENTRY0,POLL_NC,ret;

SUB_RAMBT_END_RES_H:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b2=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b2;
j3_ram_keepb_check_res_h:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,a2=2000;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,a<-a2;
j1_ram_keepa_check_res_h:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rpt=100;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_CP;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rpt=100;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (ferr) j2_ram_end_check_res_h;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!atc) j1_ram_keepa_check_res_h,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!btc) j3_ram_keepb_check_res_h,b--;
j2_ram_end_check_res_h:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,ret;

SUB_RAMBT_END_LPREAD:entry
        EXTCYL,CLK,/*LP_CLK,*/RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,b2=EXT_DATA1;
        EXTCYL,CLK,/*LP_CLK,*/RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=4000;

        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b2;
j3_ram_keepb_lpread_check:
        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,a2=30;
        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,a<-a2;
j1_ram_keepa_lpread_check:
        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=100;
        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_CP,DEBUG_L;
        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=100;
        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (ferr) j2_ram_end_lpread_check;
        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!atc) j1_ram_keepa_lpread_check,a--;
        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!btc) j3_ram_keepb_lpread_check,b--;
j2_ram_end_lpread_check:
        EXTCYL,CLK_L,LP_CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=2000;
        EXTCYL,CLK_L,LP_CLK,RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,CLK_L,LP_CLK,RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,    RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,    RES_L,MODE_ENTRY0,POLL_NC,ret;

SUB_RAMBT_END_PE:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,b2=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,c2=EXT_DATA2;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,c<-c2;
j4_ram_keepc_check_pe:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_H;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,b<-b2;
j3_ram_keepb_check_pe:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_H,a2=2000;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,a<-a2;
j1_ram_keepa_check_pe:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_H,rpt=100;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_CP,DEBUG_H;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_H,rpt=100;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (ferr) j2_ram_end_check_pe;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!atc) j1_ram_keepa_check_pe,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!btc) j3_ram_keepb_check_pe,b--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!ctc) j4_ram_keepc_check_pe,c--;
j2_ram_end_check_pe:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=20000;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,    RES_L,MODE_ENTRY0,POLL_NC;
        EXTCYL,    RES_L,MODE_ENTRY0,POLL_NC,ret;
	
SUB_RAMBT_TCEHCK_POLL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,b2=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b2;
j3_ram_tcheck_keepb_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,a2=2000;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,a<-a2;
j1_ram_tcheck_keepa_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,TCHECK_CP,DEBUG_H;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=100;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (ferr) j2_ram_tcheck_end_check;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!atc) j1_ram_tcheck_keepa_check,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!btc) j3_ram_tcheck_keepb_check,b--;
j2_ram_tcheck_end_check:
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1,POLL_NC,ret;

SUB_RAMBT_DPASS_H_POLL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,a2=EXT_DATA0;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b2=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b2;
j1_ram_dpass_h_keepb_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,a<-a2;
j2_ram_dpass_h_keepa_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DPASS_CP,DEBUG_H;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rpt=150;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,jump (ferr) j3_ram_dpass_h_end_flag;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!atc) j2_ram_dpass_h_keepa_check,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (!btc) j1_ram_dpass_h_keepb_check,b--;
j3_ram_dpass_h_end_flag:
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1,POLL_NC,ret;

SUB_RAMBT_DPASS_L_POLL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,a2=EXT_DATA0;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b2=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b2;
j1_ram_dpass_l_keepb_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,a<-a2;
j2_ram_dpass_l_keepa_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DPASS_CP,DEBUG_H;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rpt=150;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,jump (!ferr) j3_ram_dpass_l_end_flag;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!atc) j2_ram_dpass_l_keepa_check,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (!btc) j1_ram_dpass_l_keepb_check,b--;
j3_ram_dpass_l_end_flag:
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1,POLL_NC,ret;

SUB_RAMBT_DEND_H_POLL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,a2=EXT_DATA0;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b2=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b2;
j1_ram_dend_h_keepb_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,a<-a2;
j2_ram_dend_h_keepa_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_CP,DEBUG_H;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rpt=150;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,jump (ferr) j3_ram_dend_h_end_flag;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr   ,jump (!atc) j2_ram_dend_h_keepa_check,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC        ,jump (!btc) j1_ram_dend_h_keepb_check,b--;
j3_ram_dend_h_end_flag:
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1,POLL_NC,ret;

SUB_RAMBT_DEND_L_POLL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,a2=EXT_DATA0;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b2=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b2;
j1_ram_dend_l_keepb_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,a<-a2;
j2_ram_dend_l_keepa_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_CP,DEBUG_H;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rpt=150;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,jump (!ferr) j3_ram_dend_l_end_flag;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr   ,jump (!atc)  j2_ram_dend_l_keepa_check,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC        ,jump (!btc)  j1_ram_dend_l_keepb_check,b--;
j3_ram_dend_l_end_flag:
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1,POLL_NC,ret;


SUB_RAMBT_DEND_POLL:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,a2=EXT_DATA1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,a<-a2;
j1_ram_dend_keep_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_CP,DEBUG_H;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=1000;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,jump (ferr) j2_ram_dend_reset_check;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!atc) j1_ram_dend_keep_check,a--;

        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,ret;
j2_ram_dend_reset_check:
        EXTCYL,CLK,RES_L,BOOT_CTRL1,POLL_NC,ret;

SUB_TCHECK_MONITOR:entry
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=20000;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,a2=1600; // a loop = 0.1ms@31ns
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,b2=20;   // b loop = 2ms@31ns
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,b<-b2;
j1_dpass_keepb_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,a<-a2;
j2_dpass_keepa_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DPASS_CP,DEBUG_H;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_H,rpt=200;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,jump (ferr) j3_dpass_keepmain_check;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!atc) j2_dpass_keepa_check,a--;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,rerr,jump (!btc) j1_dpass_keepb_check,b--;
j3_dpass_keepmain_check:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,c1=80;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,y1=0;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,x1=0;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,x<-x1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,y<-y1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,c<-c1;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_H,rerr;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_H,rpt=200;
        EXTCYL,CLK,RES_H,BOOT_CTRL1,POLL_NC,DEBUG_L,rpt=200;

        EXTCYL,CLK,RES_H,BOOT_CTRL1,DEBUG_L,TCHECK_CP,SD_TCH,ecrlog;                                              // y:0,x:0
j4_tcheck_logmain:
        EXTCYL,CLK,RES_H,BOOT_CTRL1,TCHECK_CP,SD_TCH,ecrlog,y++,rpt=0xFF,DEBUG_H;                         // y:1~255 x:**
        EXTCYL,CLK,RES_H,BOOT_CTRL1,TCHECK_CP,SD_TCH,ecrlog,x++,y<-y1,--c,jump (!ctc) j4_tcheck_logmain,DEBUG_L;  // y:0,x:+1 LoopBack
        EXTCYL,CLK_L,RES_H,BOOT_CTRL1,POLL_NC,ret;

}


@pattern DC_TEST_PATTERN
{
/************************************************************************
 * Open / Short Test entry
 ************************************************************************/
OPENS_SHORTS:entry

        NSEC150,        vec, rerr, format op_pins_0_31 nr=-1;
        NSEC150,        vec;
        NSEC150,        vec;
        NSEC150,        quit, vec;

OPENS_SHORTS_END:entry

        NSEC150,        vec, rerr, RELAY_FF, format op_pins_0_31 nr=0, RELAY_FF;
        NSEC150,        vec;
        NSEC150,        vec;
        NSEC150,        vec;
        NSEC150,        vec, rerr, RELAY_FF, format op_pins_0_31 nc=0, RELAY_FF;
        NSEC150NOINV,   vec, RELAY_FF;
        NSEC150NOINV,   vec;
        NSEC150NOINV,   quit, vec;

RELAY_ALL_OFF:entry
        NSEC150NOINV,   vec, format all_pe_0_31 nr=0;
        NSEC150NOINV,   vec, RELAY_00, rpt=4000;     /* 150ns*4000=600us *//* HFS-1A max 0.5ms */
        NSEC150NOINV,   vec, RELAY_00, quit;

RELAY_SET:entry
        NSEC150,   vec, RELAY_00,format ex_vrefh nr=1;
        NSEC150,   vec, RELAY_00,format ex_vrefh nr=1,PORLVDTST_H, rpt=4000;        /* 150ns*4000=600us *//* HFS-1A max 0.5ms */
        NSEC150,   vec, RELAY_00,format ex_vrefh nr=1, quit;
POWERON_TEST:entry
        NSEC150,   vec, RELAY_00,format all_pe_0_31 nr=0,rpt=4000;
        NSEC150,   vec, RELAY_00,PORLVDTST_H,DEBUG_H, rpt=4000;        /* 150ns*4000=600us *//* HFS-1A max 0.5ms */
        NSEC150,   vec, RELAY_00,DEBUG_L, quit;
POWERON_TEST2:entry
        NSEC150,RES_L,rpt=4000;
        EXTCYL,RES_L,rpt=4000;
        NSEC150,   vec, RELAY_00, quit;
POWERON_TEST3:entry
        EXTCYL,RES_L,CLK_L,rpt=4000;
        EXTCYL,RES_L,CLK,rpt=4000;
        EXTCYL,RES_L,CLK,DEBUG_H,rpt=4000;
        EXTCYL,RES_H,CLK,MODE_ENTRY0,DAXS_DATA_NC,format poweron_debug nr=1,rpt=4000;
        EXTCYL,RES_H,CLK,rpt=4000;
        NSEC150,   vec, RELAY_00, quit;

ISTBY_RESET:entry
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,x=0x00,y=0x00;
        EXTCYL,CLK,RES_L,rpt=20;
        EXTCYL,CLK_L,RES_L, quit;

}


@pattern MINORI_PATTERN
{
MINORI_MODE_ENTRY:entry
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,x=0x00,y=0x00;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,a2=1; // a2:4MHz=1,8MHz=2... wait
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,b2=1; // b2:4MHz=1,8MHz=2... wait
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,b<-b2;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,dl=EXT_ME_VREF_FLAG;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=5500; // RES_L 1ms=250ns*4000 wait	
j1_modeentry_minori:
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,b--;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=10;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,jump(!btc) j1_modeentry_minori;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT7;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT6;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT5;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT4;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT3;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT0;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_MINORI_SMD4;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_MINORI_SMD3;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_MINORI_SMD2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_MINORI_SMD1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_MINORI_SMD0;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFHEN, VREFH_SD;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFEN,  VREF_SD, call SUB_ID_SET;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=5;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,a<-a2;
j2_modeentry_minori:
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,a--;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=1200; //300us=250ns*1200 wait
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,jump(!atc) j2_modeentry_minori;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,ret;



MINORI_TDR00_02:entry
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,dl=EXT_DATA1;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
