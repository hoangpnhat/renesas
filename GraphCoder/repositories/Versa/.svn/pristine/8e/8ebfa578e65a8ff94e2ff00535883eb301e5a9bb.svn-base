        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI3;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI5;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI6;
        EXTCYL,CLK,RES_H,TMS_H,TDI_DR,SD_TDI7;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI0,dl=EXT_DATA2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI3;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI5;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI6;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI7;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI0,dl=EXT_DATA3;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI3;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI5;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI6;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI7;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI0,dl=EXT_DATA4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI3;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI5;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI6;
        EXTCYL,CLK,RES_H,TMS_H,TDI_DR,SD_TDI7;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,quit;

MINORI_MAIN:entry
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,DEBUG_L,a1=EXT_DATA0; // x-inc number
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y2=EXT_DATA1; // init y-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,x2=EXT_DATA2; // init x-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,b1=EXT_DATA3; // Read-Loop b1*10000 cycle
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,dl=0xFF;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,rpt=500;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,a<-a1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y1=0;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y<-y2,x<-x2;
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,DEBUG_H; // y:0,x:0 start
j1_yinc_minori:
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,y++,rpt=0xFF;                               // y:1~255 x:**
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,x++,y<-y1,--a,jump (!atc) j1_yinc_minori;   //y:0,x:+1 LoopBack
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,y++,rpt=0x8C;                                 // y:1~255 x:**
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,a=0,DEBUG_L;
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,b<-b1;
j2_bloop_minori:
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,rpt=0x1000;
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,b--,jump (!btc) j2_bloop_minori;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,call SUB_MINORI_OUT;
        EXTCYL,CLK,RES_L,TMS_L,TDI_NP,quit;

MINORI_LOOP:entry
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,DEBUG_L,a1=EXT_DATA0; // x-inc number
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y2=EXT_DATA1; // init y-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,x2=EXT_DATA2; // init x-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,b1=EXT_DATA3; // Read-Loop b1*10000 cycle
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,c1=EXT_DATA4; // Read-Loop b1*10000 cycle
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,dl=0xFF;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,rpt=500;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,a<-a1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y1=0;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y<-y2,x<-x2;
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,DEBUG_H; // y:0,x:0 start
j1_yinc_minori_loop:
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,y++,rpt=0xFF;                               // y:1~255 x:**
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,x++,y<-y1,--a,jump (!atc) j1_yinc_minori_loop;   //y:0,x:+1 LoopBack
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,y++,rpt=0x8C;                                 // y:1~255 x:**
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,a=0,DEBUG_L;
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,c<-c1;
j3_cloop_minori_loop:
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,b<-b1;
j2_bloop_minori_loop:
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,rpt=0x3C18;
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,b--,jump (!btc) j2_bloop_minori_loop;
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,c--,jump (!ctc) j3_cloop_minori_loop;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,call SUB_MINORI_OUT;
        EXTCYL,CLK,RES_L,TMS_L,TDI_NP,quit;

MINORI_CRY_STA:entry
        EXTCYL,CLK_L,RES_H,TMS_L,TDI_NP,DEBUG_L,a1=EXT_DATA0; // x-inc number
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y2=EXT_DATA1; // init y-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,x2=EXT_DATA2; // init x-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,b1=EXT_DATA3; // Read-Loop b1*10000 cycle
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,c1=EXT_DATA4; // Read-Loop b1*10000 cycle
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,dl=0xFF;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,rpt=500;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,a<-a1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y1=0;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y<-y2,x<-x2;
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,DEBUG_H; // y:0,x:0 start
j1_yinc_minori_cry:
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,y++,rpt=0xFF;                               // y:1~255 x:**
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,x++,y<-y1,--a,jump (!atc) j1_yinc_minori_cry;   //y:0,x:+1 LoopBack
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,y++,rpt=0x8C;                                 // y:1~255 x:**
        EXTCYL,CLK_L,RES_H,TMS_L,TDI_NP,a=0,DEBUG_L;
        EXTCYL,CLK_L,RES_H,TMS_L,TDI_NP,rpt=20000;
        EXTCYL,CLK_L,RES_H,TMS_L,TDI_NP,quit;

MINORI_CRY_LOOP:entry
        EXTCYL,CLK_L,RES_H,TMS_L,TDI_NP,b1=EXT_DATA0; // Read-Loop b1*10000 cycle
        EXTCYL,CLK_L,RES_H,TMS_L,TDI_NP,c1=EXT_DATA1; // Read-Loop b1*10000 cycle
        EXTCYL,CLK_L,RES_H,TMS_L,TDI_NP,c<-c1;
j3_cloop_minori_cry_loop:
        EXTCYL2,CLK_L,RES_H,TMS_L,TDI_NP,b<-b1;
j2_bloop_minori_cry_loop:
        EXTCYL2,CLK_L,RES_H,TMS_L,TDI_NP,rpt=0x1000;
        EXTCYL2,CLK_L,RES_H,TMS_L,TDI_NP,b--,jump (!btc) j2_bloop_minori_cry_loop;
        EXTCYL2,CLK_L,RES_H,TMS_L,TDI_NP,c--,jump (!ctc) j3_cloop_minori_cry_loop;
        EXTCYL2,CLK_L,RES_H,TMS_L,TDI_NP,quit;


MINORI_CRY_END:entry
        EXTCYL,CLK_L,RES_H,TMS_L,TDI_NP,RELAY_LB3_OFF;
        EXTCYL,CLK_L,RES_H,TMS_L,TDI_NP,rpt=40000;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,call SUB_MINORI_OUT;
        EXTCYL,CLK,RES_L,TMS_L,TDI_NP,quit;


MINORI_MAIN_BI_STA:entry
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,a1=EXT_DATA1; // x-inc number
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y2=EXT_DATA2; // init y-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,x2=EXT_DATA3; // init x-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y1=0;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,dl=0xFF;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,rpt=1900;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,a<-a1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y<-y2,x<-x2;
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem; // y:0,x:0 start
j1_yinc_minori_bi:
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,DEBUG_L,y++,rpt=0xFF; // y:1~255 x:**
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,DEBUG_L,x++,y<-y1,--a,jump (!atc) j1_yinc_minori_bi;   //y:0,x:+1 LoopBack
        EXTCYL,CLK,RES_H,TD_BM,SD_MINORI,bmem,DEBUG_L,y++,rpt=0x8C; // y:1~255 x:**
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,a=0;
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,b1=140;
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,b<-b1;
j2_bloop_minori_bi:
        EXTCYL2,CLK,RES_H,TMS_L,TDI_NP,DEBUG_H,rpt=200;
        EXTCYL2,CLK_H,RES_H,TMS_L,TDI_NP,quit;


MINORI_MAIN_BI_END:entry
        EXTCYL,CLK,RES_H,TDM_OUT0,x1=0;
        EXTCYL,CLK,RES_H,TDM_OUT1,y1=0;
        EXTCYL,CLK,RES_H,TDM_OUT2,y<-y1,x<-x1;
        EXTCYL,CLK,RES_H,TDM_OUT3;
        EXTCYL,CLK,RES_H,TDM_OUT4;
        EXTCYL,CLK,RES_H,TDM_OUT5,TDO_CP,SDL0,ecrlog,y++;
        EXTCYL,CLK,RES_H,TDM_OUT6,TDO_CP,SDL0,ecrlog,y++;
        EXTCYL,CLK,RES_H,TDM_OUT7;
        EXTCYL,CLK,RES_H,TDM_OUT8;
        EXTCYL,CLK,RES_H,TDM_OUT9;
        EXTCYL,CLK,RES_H,TDM_OUT10;
        EXTCYL,CLK,RES_H,TDM_OUT11;
        EXTCYL,CLK,RES_H,TDM_OUT12;
        EXTCYL,CLK,RES_H,TDM_OUT13;
        EXTCYL,CLK,RES_H,TDM_OUT14;
        EXTCYL,CLK,RES_H,TDM_OUT15;
        EXTCYL,CLK,RES_H,TDM_OUT16;
        EXTCYL,CLK,RES_H,TDM_OUT17;
        EXTCYL,CLK,RES_H,TDM_OUT18;
        EXTCYL,CLK,RES_H,TDM_OUT19;
        EXTCYL,CLK,RES_H,TDM_OUT20;
        EXTCYL,CLK,RES_H,TDM_OUT21;
        EXTCYL,CLK,RES_H,TDM_OUT22;
        EXTCYL,CLK,RES_H,TDM_OUT23;
        EXTCYL,CLK,RES_H,TDM_OUT24;
        EXTCYL,CLK,RES_H,TDM_OUT25;
        EXTCYL,CLK,RES_H,TDM_OUT26;
        EXTCYL,CLK,RES_H,TDM_OUT27;
        EXTCYL,CLK,RES_H,TDM_OUT28;
        EXTCYL,CLK,RES_H,TDM_OUT29;
        EXTCYL,CLK,RES_H,TDM_OUT30;
        EXTCYL,CLK,RES_H,TDM_OUT31;
        EXTCYL,CLK,RES_H,TDM_OUT32;
        EXTCYL,CLK,RES_H,TDM_OUT33;
        EXTCYL,CLK,RES_H,TDM_OUT34;
        EXTCYL,CLK,RES_H,TDM_OUT35;
        EXTCYL,CLK,RES_H,TDM_OUT36;
        EXTCYL,CLK,RES_H,TDM_OUT37;
        EXTCYL,CLK,RES_H,TDM_OUT38;
        EXTCYL,CLK,RES_H,TDM_OUT39;
        EXTCYL,CLK,RES_H,TDM_OUT40;
        EXTCYL,CLK,RES_H,TDM_OUT41;
        EXTCYL,CLK,RES_H,TDM_OUT42;
        EXTCYL,CLK,RES_H,TDM_OUT43;
        EXTCYL,CLK,RES_H,TDM_OUT44;
        EXTCYL,CLK,RES_H,TDM_OUT45,b=0xFF;
        EXTCYL,CLK,RES_H,TDM_OUT46,a=1;
        EXTCYL,CLK,RES_H,TDM_OUT47,y<-y2,x<-x2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog;     //rf
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-data(dummy)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-data(dummy)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-data(main)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-data(main)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //sel
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //rf
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //data1-ff(32bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //data1-ff(32bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL1,ecrlog,y++; //bitwt(2bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog;     //bitwt(2bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //bs1ff
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //sel
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //rf
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL1,ecrlog,y++; //bitwt(2bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog;     //bitwt(2bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //bs1ff
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //sel
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //rf
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL1,ecrlog,y++; //bitwt(2bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog;     //bitwt(2bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //bs1ff
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //sel
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,y++; //dummy
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-info(100bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-info(100bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-info(100bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-info(100bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-info(100bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-info(100bit)
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++,call SUB_MINORI_DATAOUT; //fail-info(100bit)
        EXTCYL,CLK,RES_L,TMS_L,TDI_NP,quit;


SITE0_WAIT:entry
        EXTCYL2,DEBUG_H,dl=0x00;
        EXTCYL2,DEBUG_H,rpt=900;
        EXTCYL2,DEBUG_L,quit;


}

@subroutine MINORI_DATA
{
SUB_MINORI_DATAOUT:entry
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL6,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL5,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL4,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL3,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL2,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL1,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL7,ecrlog,y++;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL6,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL5,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL4,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL3,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL2,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL1,ecrlog;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,TDO_CP,SDL0,ecrlog,ret;


}
@subroutine MINORI_OUT
{
SUB_MINORI_OUT:entry
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,a1=EXT_DATA0; // x-inc number
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y2=EXT_DATA1; // init y-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,x2=EXT_DATA2; // init x-addr
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y1=0;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,dl=0xFF;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,a<-a1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,y<-y2,x<-x2;
        EXTCYL,CLK,RES_H,TD_BM,TDO_CP,SD_MINORI_OUT,bmem,ecrlog,DEBUG_H;                                       // y:0 x:**
j1_sub_minori_out:
        EXTCYL,CLK,RES_H,TD_BM,TDO_CP,SD_MINORI_OUT,bmem,ecrlog,y++,rpt=0xFF;                                  // y:1~255 x:**
        EXTCYL,CLK,RES_H,TD_BM,TDO_CP,SD_MINORI_OUT,bmem,ecrlog,x++,y<-y1,--a,jump (!atc) j1_sub_minori_out;   // y:0,x:+1 LoopBack;
        EXTCYL,CLK,RES_H,TD_BM,TDO_CP,SD_MINORI_OUT,bmem,ecrlog,y++,rpt=0x65;                                  // y:1~255 x:**
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,DEBUG_L,ret;

}


@pattern MINORI_PATTERN_LP
{
MINORI_LP_ALL:entry
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,a1=EXT_DATA0,DEBUG_L;        // 1st x-inc number
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,b1=EXT_DATA1;        // 2nd x-inc number
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,c1=EXT_DATA2;        // 3rd x-inc number
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,a2=EXT_DATA3;        // 4th x-inc number
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,rpt=2000,TMS_H;
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,y1=0;
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,y2=0;
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,x2=0;
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,y<-y2,x<-x2,dl=0x00; // Initial Addr Set
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,a<-a1,b<-b1,c<-c1;   // X-addr loop Set
        TS6 ,CLK,RES_H,TRST_L,MINORI_LP_APG,SDLP,bmem;                                               // y:0,x:0 start
j1_minori_lpread1:
        TS6 ,CLK,RES_H,TRST_L,MINORI_LP_APG,SDLP,bmem,y++,rpt=0xFF;                                  // y:1~255 x:**
        TS6 ,CLK,RES_H,TRST_L,MINORI_LP_APG,SDLP,bmem,x++,y<-y1,--a,jump (!atc) j1_minori_lpread1;   // y:0,x:+1 LoopBack
        TS6 ,CLK,RES_H,TRST_L,MINORI_LP_APG,SDLP,bmem,y++,rpt=10,DEBUG_H;                            // y:1~EXT_DATA x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,y++,rpt=15;                            // y:EXT_DATA~255 x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,x++,y<-y1,DEBUG_L;                                     // y:0,x:+1
j2_minori_lpread1:
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,y++,rpt=0xFF;                                  // y:1~255 x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,x++,y<-y1,--b,jump (!btc) j2_minori_lpread1;   // y:0,x:+1 LoopBack
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,y++,rpt=10,DEBUG_H;                            // y:1~EXT_DATA x:**
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,y++,rpt=15;                            // y:EXT_DATA~255 x:**
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,x++,y<-y1,DEBUG_L;                                     // y:0,x:+1
j3_minori_lpread1:
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,y++,rpt=0xFF;                                  // y:1~255 x:**
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,x++,y<-y1,--c,jump (!ctc) j3_minori_lpread1;   // y:0,x:+1 LoopBack
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,y++,rpt=10,DEBUG_H;                            // y:1~EXT_DATA x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,y++,rpt=15;                            // y:EXT_DATA~255 x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,x++,y<-y1,a<-a2,DEBUG_L;                               // y:0,x:+1
j4_minori_lpread1:
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,y++,rpt=0xFF;                                  // y:1~255 x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,x++,y<-y1,--a,jump (!atc) j4_minori_lpread1;   // y:0,x:+1 LoopBack
        TS13,CLK,RES_H,TRST_H              ,dl=0x00;
        TS13,CLK,RES_H,TRST_H              ,rpt=1000;
        TS13,CLK,RES_L,TRST_L              ,rpt=3000;
        TS13,CLK,RES_L,TRST_L,quit;

MINORI_LP_ALL_REPEAT:entry
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,a1=EXT_DATA0,DEBUG_L;        // 1st x-inc number
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,b1=EXT_DATA1;        // 2nd x-inc number
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,c1=EXT_DATA2;        // 3rd x-inc number
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,c2=EXT_DATA3;        // CLK Repeat number
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,a2=EXT_DATA4;        // 4th x-inc number
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,rpt=2000,TMS_H;
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,y1=0;
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,y2=0;
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,x2=0;
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,y<-y2,x<-x2,dl=0x00; // Initial Addr Set
        TS6 ,CLK,RES_L,TRST_L,MINORI_LP_APG          ,a<-a1,b<-b1,c<-c2;   // X-addr loop Set
        TS6 ,CLK,RES_H,TRST_L,MINORI_LP_APG,SDLP,bmem;                                               // y:0,x:0 start
j1_minori_lpread1_re:
        TS6 ,CLK,RES_H,TRST_L,MINORI_LP_APG,SDLP,bmem,y++,rpt=0xFF;                                  // y:1~255 x:**
        TS6 ,CLK,RES_H,TRST_L,MINORI_LP_APG,SDLP,bmem,x++,y<-y1,--a,jump (!atc) j1_minori_lpread1_re;   // y:0,x:+1 LoopBack
        TS6 ,CLK,RES_H,TRST_L,MINORI_LP_APG,SDLP,bmem,y++,rpt=10,DEBUG_L;                            // y:1~EXT_DATA x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,y++,rpt=15;                            // y:EXT_DATA~255 x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,x++,y<-y1,DEBUG_L;                                     // y:0,x:+1
j2_minori_lpread1_re:
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,y++,rpt=0xFF;                                  // y:1~255 x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,x++,y<-y1,--b,jump (!btc) j2_minori_lpread1_re;   // y:0,x:+1 LoopBack
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,y++,rpt=10,DEBUG_L;                            // y:1~EXT_DATA x:**
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,y++,rpt=15;                            // y:EXT_DATA~255 x:**
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,x++,y<-y1,c<-c2,DEBUG_L;                                     // y:0,x:+1
j5_minori_lpread1_re:
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,rpt=3200,DEBUG_H;
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,--c,jump (!ctc) j5_minori_lpread1_re;        //CLK Repeat
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,c<-c1;
j3_minori_lpread1_re:
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,y++,rpt=0xFF,DEBUG_L;                                  // y:1~255 x:**
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,x++,y<-y1,--c,jump (!ctc) j3_minori_lpread1_re;   // y:0,x:+1 LoopBack
        TS15,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,y++,rpt=10,DEBUG_L;                            // y:1~EXT_DATA x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,y++,rpt=15;                            // y:EXT_DATA~255 x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,TDO_CP,ecrlog,x++,y<-y1,a<-a2,DEBUG_L;                               // y:0,x:+1
j4_minori_lpread1_re:
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,y++,rpt=0xFF;                                  // y:1~255 x:**
        TS13,CLK,RES_H,TRST_H,MINORI_LP_APG,SDLP,bmem,x++,y<-y1,--a,jump (!atc) j4_minori_lpread1_re;   // y:0,x:+1 LoopBack
        TS13,CLK,RES_H,TRST_H              ,dl=0x00;
        TS13,CLK,RES_H,TRST_H              ,rpt=1000;
        TS13,CLK,RES_L,TRST_L              ,rpt=3000;
        TS13,CLK,RES_L,TRST_L,quit;

}
