        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_DR,SDL0;
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_DR,ret;

SUB_DAXS_WRITE:entry
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,b<-b1;
loop_wr_1st_y2:
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,rpt=4;
loop_wr_1st_x2:
    EXTCYL,CLK,RES_H,DAXS_STATE_L,DAXS_DATA_NC,DEBUG_L,call SUB_DAXS_WRITE_32BIT;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,y=y+4;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,jump (!atc) loop_wr_1st_y2,a--;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,DEBUG_H,y=0;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,a<-a1;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,x++;
    EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,jump (!btc) loop_wr_1st_x2,b--;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,ret;

SUB_DAXS_READOUT:entry
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,b<-b1;
loop_rdout_1st_y2:
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,rpt=4;
loop_rdout_1st_x2:
    EXTCYL,CLK,RES_H,DAXS_STATE_L,DAXS_DATA_NC,DEBUG_L,call SUB_DAXS_READOUT_32BIT;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,y=y+4;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,jump (!atc) loop_rdout_1st_y2,a--;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,DEBUG_H,y=0;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,a<-a1;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,x++;
    EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,jump (!btc) loop_rdout_1st_x2,b--;
	EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,ret;


SUB_DAXS_END:entry
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC;
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,rpt=20;
        EXTCYL,CLK,RES_L,DAXS_STATE_H,DAXS_DATA_NC;
        EXTCYL,CLK,RES_L,DAXS_STATE_H,DAXS_DATA_NC,ret;

}

