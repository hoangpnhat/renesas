        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI6;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI7;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI0,dl=EXT_DATA4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI3;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI5;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI6;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI7;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI0,dl=EXT_DATA5;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI3;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI5;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI6;
        EXTCYL,CLK,RES_H,TMS_H,TDI_DR,SD_TDI7;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,quit;


MINORI_TDR04:entry
        EXTCYL,    RES_H,TMS_L,TDI_NP,rpt=30;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,dl=0x18;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI0;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI3;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI5;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI6;
        EXTCYL,CLK,RES_H,TMS_H,TDI_DR,SD_TDI7;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP;
	EXTCYL,CLK,RES_H,TMS_L,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI0,dl=EXT_DATA2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI1;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI2;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI3;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI4;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI5;
        EXTCYL,CLK,RES_H,TMS_L,TDI_DR,SD_TDI6;
        EXTCYL,CLK,RES_H,TMS_H,TDI_DR,SD_TDI7;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP;
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,quit;

MINORI_TDR03:entry
        EXTCYL,CLK,RES_H,TMS_L,TDI_NP,dl=0xE8;
        EXTCYL,CLK,RES_H,TMS_H,TDI_NP;
