/***********************************************************************
 * Define Include file
 ***********************************************************************/
#include "RC04EX_def.h"
#include "RC04EX_cyc.h"
#include "RC04EX_pdf.h"
#include "V4400HW.h"  /* V4000 */
#include "common.h"

/***********************************************************************
 * command line parameters are optional, but must be first statement
 * set vector width -- usually 64 (v210x system)
 ***********************************************************************/

#ifdef V5KONLY
@sites  1             /* V5000 */
@sitechannels 0, 32   /* V5000 */
@counterfix pre       /* V5000 */
#endif
#ifdef V4KONLY
@sites 1              /* V4000 */
@sitechannels 0, 64   /* V4000 */
@counterfix pre       /* V4000 */
#endif

/************************************************************************
 * define pin groupings for use in format statments
 ************************************************************************/
#include "RC04EX_AGR.h"

/************************************************************************
 * Define timing gruops
 * note we are currently using the default
 * time = ((group number + 1) * 50ns)
 * assignment, but this can be changed with the set_cycle_time()
 * command.
 ************************************************************************/

/************************************************************************
 * acam and ecam section
 ************************************************************************/
@acam  sda_7{ daxs_datai_ext:dl(7), daxs_datao_ext:dl(7) }  /* D7 for write                 */
@acam  sda_6{ daxs_datai_ext:dl(6), daxs_datao_ext:dl(6) }  /* D6 for write                 */
@acam  sda_5{ daxs_datai_ext:dl(5), daxs_datao_ext:dl(5) }  /* D5 for write                 */
@acam  sda_4{ daxs_datai_ext:dl(4), daxs_datao_ext:dl(4) }  /* D4 for write                 */
@acam  sda_3{ daxs_datai_ext:dl(3), daxs_datao_ext:dl(3) }  /* D3 for write                 */
@acam  sda_2{ daxs_datai_ext:dl(2), daxs_datao_ext:dl(2) }  /* D2 for write                 */
@acam  sda_1{ daxs_datai_ext:dl(1), daxs_datao_ext:dl(1) }  /* D1 for write                 */
@acam  sda_0{ daxs_datai_ext:dl(0), daxs_datao_ext:dl(0) }  /* D0 for write                 */

/** RX200é╠chÉ▌ÆĶé╠Å┌Źūé═Ģs¢Š **/
@ecam  sde_7{ dl(7):daxs_datao_ext, dl(3):daxs_datai_ext }  /* D7 for read ł╚ē║é╠dataié╠É▌ÆĶé═CHÅšō╦æ╬Ź¶ */
@ecam  sde_6{ dl(6):daxs_datao_ext, dl(3):daxs_datai_ext }  /* D6 for read                  */
@ecam  sde_5{ dl(5):daxs_datao_ext, dl(3):daxs_datai_ext }  /* D5 for read                  */
@ecam  sde_4{ dl(4):daxs_datao_ext, dl(3):daxs_datai_ext }  /* D4 for read                  */
@ecam  sde_3{ dl(3):daxs_datao_ext }    /* D3 for read                  */
@ecam  sde_2{ dl(2):daxs_datao_ext, dl(3):daxs_datai_ext }  /* D2 for read                  */
@ecam  sde_1{ dl(1):daxs_datao_ext, dl(3):daxs_datai_ext }  /* D1 for read                  */
@ecam  sde_0{ dl(0):daxs_datao_ext, dl(3):daxs_datai_ext }  /* D0 for read                  */

@ecam  LP_ecam{ dl(0):daxs_datao_ext }
@ecam  sde_minori{ dl(3):daxs_datao_ext }

@ecam  tcheck_ecam{ dl(0):tcheck_ext,dl(1):tcheck_ext,dl(2):tcheck_ext,dl(3):tcheck_ext,dl(4):tcheck_ext,dl(5):tcheck_ext,dl(6):tcheck_ext,dl(7):tcheck_ext }

@acam  sd_id0{ idcode0_ext:dl(0) }
@acam  sd_id1{ idcode0_ext:dl(1) }

@acam  sd_minori{ tdi_ext:dl(0), tms_ext:dl(1) } 
@acam  sd_tdr7{ tdi_ext:dl(7) }
@acam  sd_tdr6{ tdi_ext:dl(6) }
@acam  sd_tdr5{ tdi_ext:dl(5) }
@acam  sd_tdr4{ tdi_ext:dl(4) }
@acam  sd_tdr3{ tdi_ext:dl(3) }
@acam  sd_tdr2{ tdi_ext:dl(2) }
@acam  sd_tdr1{ tdi_ext:dl(1) }
@acam  sd_tdr0{ tdi_ext:dl(0) }

// LPRead acam
@acam  LP_acam{ idcode1_ext:dl(3), idcode0_ext:dl(2), daxs_datai_ext:dl(1) }
@acam  LP_acam3{ idcode1_ext:dl(3)}
@acam  LP_acam2{ idcode0_ext:dl(2)}
@acam  LP_acam1{ daxs_datai_ext:dl(1)}

#define SDL7   acam sda_7, ecam sde_7
#define SDL6   acam sda_6, ecam sde_6
#define SDL5   acam sda_5, ecam sde_5
#define SDL4   acam sda_4, ecam sde_4
#define SDL3   acam sda_3, ecam sde_3
#define SDL2   acam sda_2, ecam sde_2
#define SDL1   acam sda_1, ecam sde_1
#define SDL0   acam sda_0, ecam sde_0

#define VREFH_SD  acam sd_id0
#define VREF_SD   acam sd_id1

#define SD_MINORI acam sd_minori
#define SD_TDI7  acam sd_tdr7
#define SD_TDI6  acam sd_tdr6
#define SD_TDI5  acam sd_tdr5
#define SD_TDI4  acam sd_tdr4
#define SD_TDI3  acam sd_tdr3
#define SD_TDI2  acam sd_tdr2
#define SD_TDI1  acam sd_tdr1
#define SD_TDI0  acam sd_tdr0

#define SDLP acam LP_acam, ecam LP_ecam
#define SD_TCH   ecam tcheck_ecam

#define SD_MINORI_OUT ecam sde_minori,SD_MINORI

/************************************************************************
 *              DAXS ACCESS
 ************************************************************************/
@pattern DAXS_ACCESS_PATTERN
{
DAXS_WRITE_BM:entry
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,rerr;          //error flag clear
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,a1=0x3F;
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,b1=EXT_DATA2;  //X_deco inc addr
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,y1=EXT_DATA3;  //Start Y-addr
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,x1=EXT_DATA4;  //Start X-addr
        EXTCYL,CLK,RES_L,MODE_ENTRY0, DAXS_DATA_NC;
        EXTCYL,CLK,RES_L,MODE_ENTRY0, DAXS_DATA_NC,call SUB_MODEENTRY_DAXS; //ModeEntry for DAXSTRANS
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,rpt=50;
        EXTCYL,CLK,RES_H,DAXS_STATE_L,DAXS_DATA_NC;               //Start DAXS Entry
        EXTCYL,CLK,RES_H,DAXS_STATE_L,DAXS_DATA_DR,SDL7,dl=0x80;  
        EXTCYL,CLK,RES_H,DAXS_STATE_L,DAXS_DATA_DR,SDL6,call SUB_DAXSTRANS_ADDR;  //DAXS Start addr input
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,y<-y1,x<-x1,a<-a1,b<-b1;
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,call SUB_DAXS_WRITE;     //DAXS Write second
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,call SUB_DAXS_END;         
        EXTCYL,CLK,RES_L,DAXS_STATE_H,DAXS_DATA_NC,quit;

DAXS_READOUT_ECR:entry
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,rerr;          //error flag clear
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,a1=0x3F;
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,b1=EXT_DATA2;  //X_deco inc addr
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,y1=EXT_DATA3;  //Start Y-addr
        EXTCYL,    RES_L,MODE_ENTRY0, DAXS_DATA_NC,x1=EXT_DATA4;  //Start X-addr
        EXTCYL,CLK,RES_L,MODE_ENTRY0, DAXS_DATA_NC;
        EXTCYL,CLK,RES_L,MODE_ENTRY0, DAXS_DATA_NC,call SUB_MODEENTRY_DAXS; //ModeEntry for DAXSTRANS
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,rpt=50;
        EXTCYL,CLK,RES_H,DAXS_STATE_L,DAXS_DATA_NC;               //Start DAXS Entry
        EXTCYL,CLK,RES_H,DAXS_STATE_L,DAXS_DATA_DR,SDL7,dl=0xC0;  
        EXTCYL,CLK,RES_H,DAXS_STATE_L,DAXS_DATA_DR,SDL6,call SUB_DAXSTRANS_ADDR;  //DAXS Start addr input
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,y<-y1,x<-x1,a<-a1,b<-b1,dl=0xFF;
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,call SUB_DAXS_READOUT;     //DAXS Write second
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,call SUB_DAXS_END;         
        EXTCYL,CLK,RES_L,DAXS_STATE_H,DAXS_DATA_NC,quit;


}

@subroutine MODE_ENTRY
{
SUB_MODEENTRY_DAXS:entry
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,x=0x00,y=0x00;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,a2=100; // 15ms over = 300us*a2 wait
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,b2=2; // 1us*b2 wait
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,b<-b2;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,dl=EXT_ME_VREF_FLAG;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=6000; // RES_L 1ms=200ns*5000 wait	
j1_modeentry_daxstrans:
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,b--;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=10;   // 1us=200ns*(5) wait
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,jump(!btc) j1_modeentry_daxstrans;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT7;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT6;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT5;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT4;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT3;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT0;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_DAXS_SMD4;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_DAXS_SMD3;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_DAXS_SMD2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_DAXS_SMD1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_DAXS_SMD0;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFHEN, VREFH_SD;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFEN,  VREF_SD, call SUB_ID_SET;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=5;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,a<-a2;
j2_modeentry_daxstrans:
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,a--;
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,rpt=1500; //300us=200ns*1500 wait
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,jump(!atc) j2_modeentry_daxstrans;
        EXTCYL,CLK,RES_H,DAXS_STATE_H,DAXS_DATA_NC,ret;


SUB_MODEENTRY_RAM:entry
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,x=0x00,y=0x00;
//        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,a1=EXT_DATA1;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,b1=EXT_DATA2;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,c1=EXT_DATA3;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,dl=EXT_ME_VREF_FLAG;
        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=20000; // RES_L 1ms=50ns*20000 wait	

//        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,a<-a1;    // 1us
j1_modeentry_rambt:
        EXTCYL2,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,rpt=EXT_DATA4;  // 1us=50ns*20 wait
//        EXTCYL2,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,a--;
//        EXTCYL2,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,jump(!atc) j1_modeentry_rambt;
        EXTCYL2,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=(2+1);

        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT1;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT2;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT7;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT6;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT5;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT4;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT3;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT2;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT1;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT0;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD4;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD3;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD2;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD1;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD0;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFHEN, VREFH_SD;
        EXTCYL2,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFEN,  VREF_SD, call SUB_ID_SET_RAMBOOT;
        EXTCYL2,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=5;

        EXTCYL2,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,b<-b1;    // 300us Wait (CLK_L)
j2_modeentry_rambt:
        EXTCYL2,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,b--;
        EXTCYL2,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,jump(!btc) j2_modeentry_rambt;
        EXTCYL2,CLK  ,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=8;

        EXTCYL2,CLK  ,RES_H,MODE_ENTRY0,DAXS_DATA_NC,c<-c1;         // 68ms wait (CLK_L)
j3_modeentry_rambt:
        EXTCYL2,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,c--;
        EXTCYL2,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=1000;
        EXTCYL2,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,jump(!ctc) j3_modeentry_rambt;
        EXTCYL2,CLK  ,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,ret;

SUB_MODEENTRY_RAM_CRY:entry
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,x=0x00,y=0x00;
//        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,a1=EXT_DATA1;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,b1=EXT_DATA2;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,c1=EXT_DATA3;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,dl=EXT_ME_VREF_FLAG;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=20000; // RES_L 1ms=50ns*20000 wait	

//        EXTCYL2,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,a<-a1;    // 1us
j1_modeentry_rambt_cry:
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,rpt=EXT_DATA4;  // 1us=50ns*20 wait
//        EXTCYL2,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,a--;
//        EXTCYL2,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,jump(!atc) j1_modeentry_rambt_cry;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=(2+1);

        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT7;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT6;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT5;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT4;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT3;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT0;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD4;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD3;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_RAM_SMD0;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFHEN, VREFH_SD;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFEN,  VREF_SD, call SUB_ID_SET;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=5;

        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,b<-b1;    // 300us Wait (CLK_L)
j2_modeentry_rambt_cry:
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,b--;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,rpt=2;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,jump(!btc) j2_modeentry_rambt_cry;
        EXTCYL,CLK  ,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,rpt=8;

        EXTCYL,CLK  ,RES_H,MODE_ENTRY0,DAXS_DATA_NC,c<-c1;         // 68ms wait (CLK_L)
j3_modeentry_rambt_cry:
        EXTCYL,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,c--;
        EXTCYL,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,rpt=1000;
        EXTCYL,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_H,jump(!ctc) j3_modeentry_rambt_cry;
        EXTCYL,CLK  ,RES_H,MODE_ENTRY0,DAXS_DATA_NC,DEBUG_L,ret;
        
SUB_MODEENTRY_ROM:entry
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,x=0x00,y=0x00;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,a1=EXT_DATA1;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,b1=EXT_DATA2;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,c1=EXT_DATA3;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,dl=EXT_ME_VREF_FLAG;
        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,rpt=5000; // RES_L 1ms=250ns*4000 wait

        EXTCYL,CLK,RES_L,MODE_ENTRY0,DAXS_DATA_NC,a<-a1;    // 1us + 2cycle
j1_modeentry_rombt:
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,a--;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,jump(!atc) j1_modeentry_rombt;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=2;

        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_STARTBIT2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT7;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT6;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT5;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT4;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT3;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_SECURITYBIT0;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_ROM_SMD4;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_ROM_SMD3;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_ROM_SMD2;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_ROM_SMD1;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_ROM_SMD0;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFHEN, VREFH_SD;
        EXTCYL,CLK,RES_H,            DAXS_DATA_NC,MODEENTRY_EXVREFEN,  VREF_SD, call SUB_ID_SET;
        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=5;

        EXTCYL,CLK,RES_H,MODE_ENTRY0,DAXS_DATA_NC,b<-b1;    // 300us Wait (CLK_L)
j2_modeentry_rombt:
        EXTCYL,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,b--;
        EXTCYL,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,jump(!btc) j2_modeentry_rombt;
        EXTCYL,CLK  ,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=8;

        EXTCYL,CLK  ,RES_H,MODE_ENTRY0,DAXS_DATA_NC,c<-c1;         // 68ms wait (CLK_L)
j3_modeentry_rombt:
        EXTCYL,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,c--;
        EXTCYL,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,rpt=1000;
        EXTCYL,CLK_L,RES_H,MODE_ENTRY0,DAXS_DATA_NC,jump(!ctc) j3_modeentry_rombt;
        EXTCYL,CLK  ,RES_H,MODE_ENTRY0,DAXS_DATA_NC,ret;

}




