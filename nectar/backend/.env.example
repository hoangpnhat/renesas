# API Keys
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# ComfyUI Settings
COMFYUI_URL=http://127.0.0.1:8188
# For RunPod: http://your-pod-id.runpod.io:8188

# Model Settings
BASE_MODEL_PATH=/path/to/models/sd_xl_base_1.0.safetensors
INSTANTID_MODEL_PATH=/path/to/models/instantid
LORA_PATH=/path/to/loras

# Generation Settings
DEFAULT_STEPS=30
DEFAULT_CFG_SCALE=7.5
INSTANTID_STRENGTH=0.85

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=True
